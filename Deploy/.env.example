# Ejemplo de variables requeridas para el deploy
# Rellena con tus valores

# Azure
AZ_SUBSCRIPTION_ID=your-subscription-id
AZ_LOCATION=centralus
RG_NAME=cnc-iot-rg

# Redes
VNET_NAME=cnciot-vnet
PUBLIC_SUBNET_NAME=public-subnet
PRIVATE_SUBNET_NAME=private-subnet
VNET_PREFIX=10.10.0.0/16
PUBLIC_SUBNET_PREFIX=10.10.1.0/24
PRIVATE_SUBNET_PREFIX=10.10.2.0/24

# Nombres recursos
APPGW_NAME=cnciot-appgw
PUBLIC_IP_NAME=cnciot-appgw-ip

# Container images (puedes usar imágenes públicas de DockerHub o ACR)
FRONTEND_IMAGE=ktalynagb/frontend:latest
BACKEND_IMAGE=ktalynagb/backend:latest
DB_IMAGE=postgres:16-alpine

# ACI container names and ports
ACI_FRONTEND_NAME=cnciot-frontend
ACI_BACKEND_NAME=cnciot-backend
ACI_DB_NAME=cnciot-db
FRONTEND_PORT=80
BACKEND_PORT=8000
DB_PORT=5432

# DB credentials (no poner secretos reales en este archivo; usar Key Vault o variables de ambiente locales)
DB_NAME=cnc_iot
DB_USER=cnc_user
DB_PASSWORD=ChangeMe123!

# App Gateway settings
APPGW_SKU=Standard_v2
APPGW_CAPACITY=1

DOCKER_USERNAME=tu_usuario_de_docker
DOCKER_PASSWORD=tu_contraseña_o_token